generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Movie {
  id        String   @id @default(uuid())
  title     String
  genre     String
  posterUrl String
  status    String   // "Watching" or "Completed"
  rating    Int      // 1 to 5
  createdAt DateTime @default(now())
}
